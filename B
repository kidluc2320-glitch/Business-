        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root { --red: #dc2626; --dark: #111827; --gray: #6b7280; --light: #f9fafb; --yellow: #fbbf24; }
        body { font-family: 'Roboto', sans-serif; color: var(--dark); background: white; }
