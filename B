        .section-sub { text-align: center; color: var(--gray); margin-bottom: 50px; }
        .svc-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 25px; }
        .svc-card { border: 2px solid #e5e7eb; border-radius: 8px; padding: 35px; transition: all 0.3s; position: relative; overflow: hidden; }
        .svc-card::before { content: ''; position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: var(--red); transform: scaleY(0); transition: transform 0.3s; }
        .svc-card:hover { border-color: var(--red); box-shadow: 0 10px 30px rgba(0,0,0,0.1); }
        .svc-card:hover::before { transform: scaleY(1); }
        .svc-card h3 { font-family: 'Oswald', sans-serif; font-size: 22px; margin-bottom: 12px; display: flex; align-items: center; gap: 10px; }
