        .cta-final p { font-size: 18px; opacity: 0.9; margin-bottom: 25px; }
        .cta-phone { font-size: 48px; font-weight: 700; color: white; text-decoration: none; display: block; margin: 20px 0; letter-spacing: 1px; }
        .hours-grid { max-width: 600px; margin: 30px auto 0; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; text-align: left; font-size: 15px; }
        footer { background: #0f172a; color: #94a3b8; padding: 50px 20px 20px; }
